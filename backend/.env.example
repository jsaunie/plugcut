# Copy to .env and fill in. All vars are prefixed PLUGCUT_.

# REQUIRED in any real environment — generate with: openssl rand -hex 32
PLUGCUT_JWT_SECRET=dev-insecure-secret-change-me
PLUGCUT_JWT_ALGORITHM=HS256
PLUGCUT_ACCESS_TOKEN_TTL_MINUTES=15
PLUGCUT_REFRESH_TOKEN_TTL_DAYS=14

# postgresql+asyncpg://user:pass@localhost:5432/plugcut  (prod)
PLUGCUT_DATABASE_URL=sqlite+aiosqlite:///./plugcut.db

PLUGCUT_DEFAULT_LOCALE=fr
